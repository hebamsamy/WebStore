@{
}

@model List<RoleViewModel>




<div class="container">
<h1>Applicaton Roles</h1>
     <p class="text-danger">@ViewBag.msg</p>
    <form asp-action="add" asp-controller="role">
        <input name="rolename" placeholder="Enter Role Name" class="form-control"/>
        <input class="btn btn-info" type="submit" value="Add Role"/>

    </form>
    
    <br />
    <br />
    <br />
    <br />
    <br />


    <table>
        <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Actions</th>

        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>
                        <a class="btn btn-primary">Edit</a>
                        <a class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>